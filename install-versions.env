# Целевая ОС
UBUNTU_VERSION=24.04
PYTHON_VERSION=3.12

# Пользователь и пути
APP_USER=botrunner
APP_GROUP=botrunner
APP_HOME=/opt/telegram-bots
APP_DIR=/opt/telegram-bots/clipsave
VENV_DIR=/opt/telegram-bots/venv
DOWNLOAD_DIR=/download
APP_SERVICE=clipsave
BACKUP_DIR=/opt/telegram-bots/clipsave/backups/db

# Сетевые параметры приложения
WEB_HOST=127.0.0.1
WEB_PORT=8093

# Node.js для yt-dlp / YouTube EJS
NODEJS_MAJOR=22

# Пакеты ОС
APT_PACKAGES="ca-certificates curl git unzip ffmpeg python3 python3-venv python3-pip sqlite3 cron ufw rsync gnupg"

# Python-пакеты с фиксированными версиями
BGUTIL_POT_PROVIDER_VERSION=1.3.1
FASTAPI_VERSION=0.135.3
UVICORN_VERSION=0.44.0
PYTHON_DOTENV_VERSION=1.2.2
YT_DLP_VERSION=2026.3.17
YT_DLP_EJS_VERSION=0.8.0
JINJA2_VERSION=3.1.6
PYTHON_MULTIPART_VERSION=0.0.26
HTTPX_VERSION=0.28.1

# PO Token Provider для yt-dlp / YouTube GVS
BGUTIL_POT_DIR=/opt/bgutil-ytdlp-pot-provider
BGUTIL_POT_SERVICE=bgutil-pot
BGUTIL_POT_REPO_URL=https://github.com/Brainicism/bgutil-ytdlp-pot-provider.git

# Angie
ANGIE_REPO_CHANNEL=main
