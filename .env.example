# =========================
# WEB SERVER
# =========================

WEB_HOST=127.0.0.1
WEB_PORT=8093

# Базовый путь (обязательно совпадает с nginx/angie)
WEB_BASE_PATH=/df2sf4gf54dfchg45dfg4h5fg4

# =========================
# БЕЗОПАСНОСТЬ
# =========================

# Секрет для подписи cookies (ОБЯЗАТЕЛЬНО поменять)
WEB_SECRET_KEY=CHANGE_THIS_SECRET_KEY_TO_RANDOM_LONG_STRING

# Ключ для входа по ссылке /login?key=...
WEB_LOGIN_KEY=CHANGE_THIS_LOGIN_KEY_TO_RANDOM_STRING

# Названия cookies (можно не менять)
WEB_COOKIE_UID=web_ytd_uid
WEB_COOKIE_SESSION=web_ytd_session

# Время жизни cookies
WEB_UID_MAX_AGE=15552000        # 180 дней
WEB_SESSION_MAX_AGE=604800      # 7 дней


# =========================
# ОГРАНИЧЕНИЯ И ОЧЕРЕДЬ
# =========================

# Максимум одновременно выполняемых задач (ВАЖНО для слабого сервера)
MAX_ACTIVE_TASKS=1

# Максимум задач от одного пользователя
MAX_ACTIVE_TASKS_PER_USER=1


# =========================
# ХРАНЕНИЕ И ОЧИСТКА
# =========================

# Через сколько удалять неактивных пользователей
USER_RETENTION_DAYS=30

# Очистка каждый день в это время (по серверу)
CLEANUP_HOUR=4
CLEANUP_MINUTE=10

# Через сколько часов очищать старые задачи из памяти
REQUEST_TTL_HOURS=1


# =========================
# ПУТИ
# =========================

# Куда сохраняются скачанные файлы
DOWNLOAD_PATH=/download

# Где хранить cookies пользователей
COOKIES_PATH=./cookies

# Где хранить данные (users, sessions, history)
DATA_PATH=./data

# Логи
LOG_PATH=./logs


# =========================
# ССЫЛКА НА СКАЧИВАНИЕ
# =========================

# Базовый URL, который отдаёт Angie/nginx
DOWNLOAD_BASE_URL=https://example.com/files


# =========================
# YT-DLP / DEBUG
# =========================

# Включить подробные логи yt-dlp (0 или 1)
DEBUG_YTDLP=0
